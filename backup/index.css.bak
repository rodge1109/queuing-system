@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400&family=IBM+Plex+Sans:wght@300;400;600&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --cds-background: #ffffff;
  --cds-layer-01: #f4f4f4;
  --cds-layer-02: #e0e0e0;
  
  --cds-text-primary: #161616;
  --cds-text-secondary: #525252;
  --cds-text-helper: #6f6f6f;
  --cds-text-on-color: #ffffff;
  
  --cds-button-primary: #0f62fe;
  --cds-button-primary-hover: #0353e9;
  --cds-button-primary-active: #002d9c;
  
  --cds-border-subtle: #c6c6c6;
  --cds-field: #f4f4f4;
  --cds-link-primary: #0f62fe;
  --cds-focus: #0f62fe;
  
  --cds-support-error: #da1e28;
  --cds-support-success: #24a148;
  --cds-support-warning: #f1c21b;
  --cds-support-info: #0f62fe;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 0 !important; /* Non-negotiable Carbon rule */
}

/* Exceptions to 0px rule */
.pill, .tag {
  border-radius: 24px !important;
}

.force-circle {
  border-radius: 9999px !important;
}

html {
  overflow-x: hidden;
  overflow-y: scroll;
  max-width: 100vw;
  background-color: var(--cds-background);
}

body {
  margin: 0;
  padding: 0;
  min-width: 320px;
  min-height: 100vh;
  max-width: 100vw;
  font-family: 'IBM Plex Sans', system-ui, sans-serif;
  color: var(--cds-text-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  position: relative;
}

h1, h2, h3 {
  font-weight: 300; /* Expressive heading default */
  letter-spacing: 0;
}

p, span, label, input, button {
  letter-spacing: 0;
}

small, .text-xs {
  letter-spacing: 0.32px; /* Caption tracking */
}

.text-sm {
  letter-spacing: 0.16px; /* Body short tracking */
}

#root {
  overflow-x: hidden;
  max-width: 100vw;
  width: 100%;
}

/* Carbon Input Pattern */
.carbon-input {
  background-color: white;
  border: 1px solid #e0e0e0;
  border-bottom: 2px solid #8d8d8d;
  transition: all 0.1s;
}

.carbon-input:focus {
  border-color: var(--cds-focus);
  border-bottom: 2px solid var(--cds-focus);
  outline: none;
}

/* Carbon Button Pattern */
.carbon-btn-primary {
  background-color: var(--cds-button-primary);
  color: var(--cds-text-on-color);
  transition: background-color 0.1s;
}

.carbon-btn-primary:hover {
  background-color: var(--cds-button-primary-hover);
}

.carbon-btn-primary:active {
  background-color: var(--cds-button-primary-active);
}

/* ========================================
   PayMongo Onboarding Form Design System
   ======================================== */

.paymongo-onboarding {
  --pm-emerald-500: #10b981;
  --pm-emerald-100: #d1fae5;
  --pm-indigo-600: #4f46e5;
  --pm-indigo-700: #4338ca;
  --pm-indigo-800: #3730a3;
  --pm-indigo-100: #c7d2fe;
  --pm-indigo-50: #eef2ff;
  
  --pm-gray-900: #111827;
  --pm-gray-700: #374151;
  --pm-gray-500: #6b7280;
  --pm-gray-400: #9ca3af;
  --pm-gray-200: #e5e7eb;
  --pm-gray-100: #f3f4f6;
  
  --pm-green-100: #dcfce7;
  --pm-green-800: #166534;
  --pm-red-500: #ef4444;
  --pm-purple-200: #ddd6fe;
  --pm-purple-600: #6d28d9;

  font-family: system-ui, -apple-system, sans-serif;
  color: var(--pm-gray-900);
  background: white;
  max-width: 680px;
  margin: 0 auto;
  padding: 24px;
}

.paymongo-onboarding * {
  border-radius: revert !important;
}

.pm-title {
  font-size: 20px;
  font-weight: 500;
  color: var(--pm-gray-900);
}

.pm-subtitle {
  font-size: 13px;
  font-weight: 400;
  color: var(--pm-gray-500);
}

.pm-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--pm-gray-900);
  display: block;
  margin-bottom: 6px;
}

.pm-input {
  height: 40px;
  padding: 0 12px;
  border: 1px solid #d1d5db;
  border-radius: 8px !important;
  font-size: 13px;
  color: var(--pm-gray-900);
  width: 100%;
  transition: all 0.2s;
}

.pm-input::placeholder {
  color: var(--pm-gray-400);
}

.pm-input:hover {
  border-color: var(--pm-gray-400);
}

.pm-input:focus {
  outline: none;
  border-color: var(--pm-indigo-600);
  box-shadow: 0 0 0 4px var(--pm-indigo-50);
}

.pm-btn-next {
  background: var(--pm-emerald-500);
  color: white;
  padding: 14px 32px;
  border-radius: 8px !important;
  font-size: 15px;
  font-weight: 500;
  transition: background 0.2s;
  border: none;
  cursor: pointer;
}

.pm-btn-next:hover {
  background: #059669;
}

.pm-btn-next:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.pm-card-tax {
  border: 2px solid var(--pm-indigo-100);
  border-radius: 12px !important;
  overflow: hidden;
  margin-bottom: 24px;
}

.pm-card-tax-header {
  background: var(--pm-indigo-50);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--pm-indigo-800);
  font-size: 13px;
  font-weight: 500;
}

.pm-card-tax-body {
  padding: 16px;
  background: white;
}

.pm-radio-option {
  padding: 12px;
  border-radius: 8px !important;
  border: 2px solid var(--pm-gray-200);
  transition: all 0.2s;
  cursor: pointer;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.pm-radio-option:hover {
  background: var(--pm-gray-100);
}

.pm-radio-option.selected {
  border-color: #6366f1;
  background: var(--pm-indigo-50);
}

.pm-radio-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--pm-gray-900);
}

.pm-radio-desc {
  font-size: 11px;
  font-weight: 400;
  color: var(--pm-gray-500);
}

.pm-upload-zone {
  padding: 20px;
  border: 2px dashed #d1d5db;
  border-radius: 10px !important;
  text-align: center;
  background: white;
  transition: all 0.2s;
  cursor: pointer;
}

.pm-upload-zone:hover {
  border-color: var(--pm-indigo-600);
  background: var(--pm-gray-100);
}

.pm-file-card {
  padding: 12px;
  border: 2px solid var(--pm-indigo-100);
  border-radius: 10px !important;
  display: flex;
  align-items: center;
  gap: 12px;
  background: white;
}

.pm-file-icon-box {
  width: 36px;
  height: 36px;
  background: var(--pm-purple-200);
  border-radius: 8px !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pm-purple-600);
}

.pm-badge-uploaded {
  background: var(--pm-green-100);
  color: var(--pm-green-800);
  font-size: 10px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 4px !important;
}

.pm-sworn-box {
  background: var(--pm-indigo-50);
  padding: 12px;
  border: 1px solid var(--pm-indigo-100);
  border-radius: 8px !important;
  font-size: 11px;
  color: var(--pm-gray-700);
}

.pm-stepper-circle {
  width: 36px;
  height: 36px;
  border-radius: 9999px !important;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  position: relative;
}

.pm-stepper-circle.active {
  background: var(--pm-emerald-500);
  color: white;
  box-shadow: 0 0 0 4px var(--pm-emerald-100);
}

.pm-stepper-circle.done {
  background: var(--pm-gray-400);
  color: white;
}

.pm-stepper-circle.inactive {
  background: var(--pm-gray-200);
  color: var(--pm-gray-400);
}

.pm-stepper-label {
  font-size: 11px;
  margin-top: 8px;
  font-weight: 400;
}

.pm-stepper-label.active {
  font-weight: 500;
  color: var(--pm-gray-900);
}

.pm-stepper-label.inactive {
  color: var(--pm-gray-400);
}

.pm-connector {
  flex: 1;
  height: 3px;
  background: var(--pm-gray-200);
  margin: 0 12px;
  margin-top: 18px;
}

.pm-connector.active {
  background: var(--pm-emerald-500);
}
